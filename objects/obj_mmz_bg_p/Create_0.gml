/// @description Add background
	
	//Inherit the parent event
	event_inherited();
	
	//Vertical scroll factor
	var v_scroll = 0.88;
	
	//Background mode (Used for BG switch)
	bg_mode = 0;
	
	//Add backgrounds, ID starting out from 0, increments by 1 with each background added
	add_background(spr_bg_mmz_p, 0, 0.9, v_scroll, -0.2, 0, 0, 0);
	add_background(spr_bg_mmz_p, 1, 0.93, v_scroll, -0.15, 0, 0, 0);
	add_background(spr_bg_mmz_p, 2, 0.99, v_scroll, -0.1, 0, 0, 0);
	add_background(spr_bg_mmz_p, 3, 0.98, v_scroll, -0.05, 0, 0, 0);
	add_background(spr_bg_mmz_p, 4, 0.94, v_scroll, -0.025, 0, 0, 0);
	add_background(spr_bg_mmz_p, 5, 0.98, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 6, 0.90, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 7, 0.85, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 8, 0.80, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 9, 0.77, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 10, 0.75, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 11, 0.73, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 12, 0.70, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 13, 0.65, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 14, 0.60, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_p, 15, 0.50, v_scroll, 0, 0, 0, 0);