/// @description Add background
	
	//Inherit the parent event
	event_inherited();
	
	//Vertical scroll factor
	var v_scroll = 0.88;
	
	//Background mode (Used for BG switch)
	bg_mode = 0;
	
	//Add backgrounds, ID starting out from 0, increments by 1 with each background added
	add_background(spr_bg_mmz_1, 0, 0.9, v_scroll, -0.2, 0, 0, 0);
	add_background(spr_bg_mmz_1, 1, 0.93, v_scroll, -0.15, 0, 0, 0);
	add_background(spr_bg_mmz_1, 2, 0.99, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 3, 0.98, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 4, 0.94, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 5, 0.90, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 6, 0.84, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 7, 0.8, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 8, 0.78, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 9, 0.72, v_scroll, 0, 0, 0, 0);
	add_background(spr_bg_mmz_1, 10, 0.68, v_scroll, 0, 0, 0, 0);